.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Build outputs
dist/
build/
*.tgz

# Testing
coverage/
.nyc_output/

# Archivos temporales
tmp/
temp/
