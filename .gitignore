# Dependencias
node_modules/

# Variables de entorno (sensibles)
.env
.env.local
.env.*.local

# NO ignorar .env.example (debe estar en el repo)
!.env.example

# Logs
logs/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Mantener directorio logs/ con .gitkeep
!logs/.gitkeep

