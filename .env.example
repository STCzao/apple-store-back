# ====================================
# CONFIGURACIÓN DEL SERVIDOR
# ====================================

# Puerto en el que correrá el servidor
# Rango válido: 1024-65535 (puertos bien conocidos 0-1023 requieren privilegios)
# Si no se define, usa 3000 por defecto
PORT=3000

# Entorno de ejecución (development, production, test)
# Si no se define, usa "development" por defecto
NODE_ENV=development

# ====================================
# BASE DE DATOS
# ====================================

# String de conexión a MongoDB
# Desarrollo local: mongodb://localhost:27017/apple-store
# Producción: mongodb+srv://usuario:password@cluster.mongodb.net/apple-store
MONGODB_CNN=mongodb://localhost:27017/apple-store

# ====================================
# AUTENTICACIÓN Y SEGURIDAD
# ====================================

# Clave secreta para firmar tokens JWT
# IMPORTANTE: Generar una clave fuerte y única en producción
# Sugerencia: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRETORPRIVATEKEY=tu_clave_secreta_super_segura_cambiar_en_produccion

# Tiempo de expiración del token JWT (en formato string)
# Ejemplos: '1h', '2d', '30m', '4h'
JWT_EXPIRATION=4h

# ====================================
# PAGOS (STRIPE) - Opcional
# ====================================

# Clave pública de Stripe (para el frontend)
# STRIPE_PUBLIC_KEY=pk_test_xxx

# Clave secreta de Stripe (para el backend)
# STRIPE_SECRET_KEY=sk_test_xxx

# Webhook secret de Stripe (para validar eventos)
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ====================================
# CORS
# ====================================

# URLs permitidas para hacer peticiones (separadas por coma)
# Ejemplo: http://localhost:5173,https://miapp.com
# ALLOWED_ORIGINS=http://localhost:5173

# ====================================
# OTROS
# ====================================

# URL base de la API (útil para enlaces en emails)
# API_URL=http://localhost:3000

# Email de contacto del administrador
# ADMIN_EMAIL=admin@applestore.com
