# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de datos ────────────────────────────────────────────────────────────
MONGODB_CNN=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_seguro
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_seguro
